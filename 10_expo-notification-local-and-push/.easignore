# When this file exists, EAS Build uses it (instead of .gitignore) to decide
# which files to upload. Mirror .gitignore here, but DO NOT list
# google-services.json so it gets uploaded to the build while staying out of git.

# dependencies
node_modules/

# standalone push notification server (not part of the app build)
push-backend/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android
